#version 450

layout(local_size_x = 1) in;

layout(set = 0, binding = 0) buffer SSBO
{
    uint v;
};

layout(set = 0, binding = 1) buffer SSBO1
{
    uint data[];
};

layout(set = 0, binding = 2) uniform UBO0
{
    uint i0;
};

layout(set = 1, binding = 0) uniform UBO1
{
    uint i1;
};

void main()
{
    v += data.length() + data[0] + data[1] + i0 + i1;
}